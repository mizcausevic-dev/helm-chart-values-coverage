{
  "name": "helm-chart-values-coverage",
  "version": "0.1.0",
  "description": "Cross-reference {{ .Values.* }} usage in a Helm chart's templates/ against the dotted keys in values.yaml. Surfaces missing-default (referenced but no default) and unused-default (declared but never referenced) gaps. Pure offline transform — no helm CLI required. Library + CLI.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/helm-chart-values-coverage"
  },
  "keywords": [
    "helm",
    "kubernetes",
    "k8s",
    "values",
    "coverage",
    "platform-engineering",
    "ci",
    "typescript"
  ],
  "bin": {
    "helm-chart-values-coverage": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts fixtures/sample-chart --format summary",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
